PROVIDER=OpenAI
MODEL_NAME=gpt-5-mini
API_KEY=
BASE_URL=

CWD=.
BASE_SYSTEM=
INCLUDE_DATE=true
LOAD_AGENTS_MD=true
AUTO_COMPACT=true
COMPACT_THRESHOLD=60000
KEEP_RECENT_ROUNDS=6
MAX_AGENTS_MD_BYTES=65536

MAX_LLM_TURNS=20
MAX_TOOL_CALLS=50
MAX_PARALLEL_TOOL_CALLS=4
MAX_CONSECUTIVE_TOOL_ERRORS=3
MAX_CONSECUTIVE_API_ERRORS=3

ENABLE_TOOL_BUDGET=true
TOOL_BUDGET_MAX_LEN=10000
TOOL_BUDGET_HEAD_LEN=3000
TOOL_BUDGET_TAIL_LEN=3000

RETRY_MAX_RETRIES=3
RETRY_INITIAL_DELAY=1s
RETRY_MAX_DELAY=60s
RETRY_MULTIPLIER=2
RETRY_JITTER=0.2

PROMPT_CACHE_ENABLED=true
PROMPT_CACHE_KEY=
PROMPT_CACHE_RETENTION=in-memory
PROMPT_CACHE_TTL=5m

LOG_PATH=.codingman.log
